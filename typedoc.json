{
  "$schema": "https://typedoc.org/schema.json",
  "entryPoints": [
    "dist/src/index.d.ts",
    "dist/src/composables/useAuth.d.ts",
    "dist/src/core/ServiceBase.d.ts",
    "dist/src/core/ServiceLocal.d.ts",
    "dist/src/core/ServiceRemote.d.ts",
    "dist/src/core/ServiceFactory.d.ts",
    "dist/src/core/extends/ExtendSettings.d.ts",
    "dist/src/core/extends/ExtendClass.d.ts",
    "dist/src/core/extends/ExtendInstance.d.ts",
    "dist/src/core/extends/ExtendMixin.d.ts",
    "dist/src/store/ServiceStore.d.ts",
    "dist/src/utils/logger.d.ts",
    "dist/src/modules/Documents.d.ts",
    "dist/src/modules/GetDocuments.d.ts",
    "dist/src/modules/SetDocuments.d.ts",
    "dist/src/modules/Users.d.ts"
  ],
  "entryPointStrategy": "expand",
  "out": "docs/api",
  "tsconfig": "tsconfig.typedoc.json",
  "readme": "README.md",
  "exclude": ["playground/**", "**/*.test.*", "**/*.spec.*"],
  "skipErrorChecking": true,
  "useTsLinkResolution": false,
  "disableSources": true,
  "intentionallyNotExported": [],
  "highlightLanguages": ["javascript", "typescript", "bash", "ini", "json"],
  "excludePrivate": false,
  "excludeProtected": false,
  "categorizeByGroup": false,
  "sort": ["source-order"],
  "plugin": [
    "typedoc-plugin-mermaid",
    "typedoc-plugin-rename-defaults"],
  "projectDocuments": [
    "README.md",
    "LICENCE.md",
  ],
  "blockTags": [
    "@alias", 
    "@classdesc", 
    "@constructor",
    "@description",
    "@example",
    "@extends",
    "@fires",
    "@fixme",
    "@function",
    "@mixin",
    "@method",
    "@module",
    "@param",
    "@property",
    "@returns",
    "@todo",
    "@type",
    "@typedef"
  ],
  "sidebarLinks": {
    "github": "https://github.com/IGNF/cartes.gouv.fr-service",
    "release": "https://github.com/IGNF/cartes.gouv.fr-service/releases",
    "package": "https://github.com/IGNF/cartes.gouv.fr-service/pkgs/npm/cartes.gouv.fr-service",
    "schema": "https://github.com/IGNF/cartes.gouv.fr-service/blob/main/docs/authentication-sequence.md"
  }
}
